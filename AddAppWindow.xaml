<Window x:Class="WhiteLabelLauncher.AddAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Application"
        Width="460" Height="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>

        <!-- Dark TextBox -->
        <Style x:Key="DarkBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#161618"/>
            <Setter Property="Foreground"      Value="#F2F2F7"/>
            <Setter Property="CaretBrush"      Value="#F2F2F7"/>
            <Setter Property="BorderBrush"     Value="#2A2A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Inter, Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="10,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF9500"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Save button â€“ orange gradient -->
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Inter, Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                    <GradientStop Color="#FF3B30" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cancel button â€“ dark ghost -->
        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Inter, Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#8E8E93"/>
            <Setter Property="Background"      Value="#1A1A1D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#222226"/>
                                <Setter Property="Foreground" Value="#AEAEB2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Browse button â€“ orange text, subtle bg -->
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Inter, Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="#FF9500"/>
            <Setter Property="Background"      Value="#201508"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2C1E0C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Inter, Segoe UI"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Medium"/>
            <Setter Property="Foreground"  Value="#8E8E93"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <!-- Root -->
    <Border CornerRadius="16" Background="#0F0F11">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2A2A2E" Offset="0"/>
                <GradientStop Color="#18181B" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Form      -->
                <RowDefinition Height="64"/>   <!-- Buttons   -->
            </Grid.RowDefinitions>

            <!-- â”€â”€ Title bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Grid Grid.Row="0" Margin="20,0,12,0"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                    <!-- Mini logo -->
                    <Border Width="24" Height="24" CornerRadius="7" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF3B30" Offset="0"/>
                                <GradientStop Color="{DynamicResource AccentColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="+" FontSize="14" FontWeight="Black" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Add Application"
                               FontFamily="Inter, Segoe UI, sans-serif"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#F2F2F7"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BrowseBtn}"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="11" Height="30" Padding="8,0"
                            Background="Transparent"
                            Foreground="#4A4A4E"
                            ToolTip="Cancel"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#1C1C1E"/>

            <!-- â”€â”€ Form â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <StackPanel Grid.Row="1" Margin="22,18,22,0">

                <!-- App Name -->
                <TextBlock Text="App Name" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <TextBox x:Name="NameBox" Style="{StaticResource DarkBox}"
                             TextChanged="NameBox_TextChanged"/>
                    <TextBlock x:Name="NameHint"
                               Text="e.g. Sample App"
                               FontFamily="Inter, Segoe UI" FontSize="12"
                               Foreground="#38383C"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </Grid>

                <!-- Executable Path -->
                <TextBlock Text="Executable Path (.exe)" Style="{StaticResource FieldLabel}"
                           Margin="0,14,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox x:Name="PathBox" Style="{StaticResource DarkBox}"
                                 TextChanged="PathBox_TextChanged"/>
                        <TextBlock x:Name="PathHint"
                                   Text="C:\Program Files\..."
                                   FontFamily="Inter, Segoe UI" FontSize="12"
                                   Foreground="#38383C"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </Grid>
                    <Button Grid.Column="2"
                            Content="Browse"
                            Style="{StaticResource BrowseBtn}"
                            Click="BrowsePath_Click"/>
                </Grid>

                <!-- App Icon (optional) -->
                <TextBlock Text="App Icon  (optional)" Style="{StaticResource FieldLabel}"
                           Margin="0,14,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- preview -->
                        <ColumnDefinition Width="12"/>    <!-- gap -->
                        <ColumnDefinition Width="*"/>     <!-- info + buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- Live icon preview square -->
                    <Border x:Name="IconPreviewBorder"
                            Grid.Column="0"
                            Width="52" Height="52" CornerRadius="14"
                            ClipToBounds="True" Cursor="Hand"
                            ToolTip="Click to browse for an icon image"
                            MouseLeftButtonUp="IconPreview_Click">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1A1D" Offset="0"/>
                                <GradientStop Color="#222226" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <!-- Custom image (shown when a file is chosen) -->
                            <Image x:Name="IconPreviewImage"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <!-- Placeholder icon (shown by default) -->
                            <TextBlock x:Name="IconPreviewPlaceholder"
                                       Text="&#xEB9F;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="#38383C"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Right side: file name + buttons -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="IconFileNameLabel"
                                   Text="No image selected"
                                   FontFamily="Inter, Segoe UI" FontSize="11"
                                   Foreground="#48484C"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Browse image"
                                    Style="{StaticResource BrowseBtn}"
                                    Height="30" Padding="10,0"
                                    Click="BrowseIcon_Click"/>
                            <Button x:Name="ClearIconBtn"
                                    Content="Clear"
                                    Style="{StaticResource CancelBtn}"
                                    Height="30" Padding="10,0"
                                    Margin="8,0,0,0"
                                    Visibility="Collapsed"
                                    Click="ClearIcon_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

            </StackPanel>

            <!-- â”€â”€ Action Buttons â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Grid Grid.Row="2" Margin="22,0,22,16" VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel"
                        Style="{StaticResource CancelBtn}"
                        Click="BtnCancel_Click"/>
                <Button Grid.Column="2" Content="Save App"
                        Style="{StaticResource SaveBtn}"
                        Click="BtnSave_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>
