<Window x:Class="WhiteLabelLauncher.AddTabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Category Tab" 
        Height="300" Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="WindowDrag_MouseDown">

    <Window.Resources>
        <!-- Sleek Icon RadioButton Style -->
        <Style x:Key="IconRadioStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="1"
                                Margin="0,0,6,6"
                                Cursor="Hand">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="#8E8E93"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF9500"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFB340"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root Dark Pane with Bento style rounded corners -->
    <Border CornerRadius="16" Background="#0F0F11" BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2A2A2E" Offset="0"/>
                <GradientStop Color="#18181B" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0"
                       Text="New Workspace Tab"
                       FontFamily="Inter, Segoe UI"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="#F2F2F7"
                       Margin="0,0,0,16"/>
                       
            <StackPanel Grid.Row="1">
                <TextBlock Text="Category Name"
                           FontFamily="Inter, Segoe UI"
                           FontSize="11" FontWeight="Medium"
                           Foreground="#8E8E93"
                           Margin="0,0,0,6"/>
                <Border Background="#1A1A1D"
                        CornerRadius="8"
                        BorderBrush="#2A2A2E" BorderThickness="1"
                        Padding="12,10"
                        Margin="0,0,0,16">
                    <TextBox x:Name="TxtCategoryName"
                             Background="Transparent"
                             Foreground="#F2F2F7"
                             BorderThickness="0"
                             FontFamily="Inter, Segoe UI"
                             FontSize="14"
                             CaretBrush="{DynamicResource AccentBrush}"/>
                </Border>

                <TextBlock Text="Select Icon"
                           FontFamily="Inter, Segoe UI"
                           FontSize="11" FontWeight="Medium"
                           Foreground="#8E8E93"
                           Margin="0,0,0,6"/>
                
                <WrapPanel x:Name="IconWrapPanel">
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE71D;" Tag="&#xE71D;" IsChecked="True" ToolTip="App"/>
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE7C3;" Tag="&#xE7C3;" ToolTip="Design"/>
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE943;" Tag="&#xE943;" ToolTip="Code"/>
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE7FC;" Tag="&#xE7FC;" ToolTip="Gaming"/>
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE8A5;" Tag="&#xE8A5;" ToolTip="Documents"/>
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE8B7;" Tag="&#xE8B7;" ToolTip="Folder"/>
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE8B2;" Tag="&#xE8B2;" ToolTip="Media"/>
                    <RadioButton Style="{StaticResource IconRadioStyle}" Content="&#xE771;" Tag="&#xE771;" ToolTip="List"/>
                </WrapPanel>

                <TextBlock x:Name="ErrorMsg"
                           Foreground="#FF3B30"
                           FontFamily="Inter, Segoe UI"
                           FontSize="11"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,10,0" Padding="16,8" Cursor="Hand"
                        Background="Transparent" Foreground="#F2F2F7" BorderThickness="0" FontFamily="Inter, Segoe UI" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="Save" Click="BtnSave_Click" Padding="16,8" Cursor="Hand" FontFamily="Inter, Segoe UI" FontSize="13" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="White"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFB340"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E08300"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
