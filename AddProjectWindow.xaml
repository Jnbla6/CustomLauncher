<Window x:Class="WhiteLabelLauncher.AddProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Project" Height="460" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <!-- Simple text box style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#101013"/>
            <Setter Property="Foreground" Value="#F2F2F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#252528"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A1D" CornerRadius="16" BorderBrush="#2A2A2E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" MouseDown="WindowDrag_MouseDown" Background="Transparent">
                <TextBlock Text="Add Manual Project" 
                           FontFamily="Inter, Segoe UI" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#F2F2F7" Margin="16,16,0,0"/>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20">
                <TextBlock Text="PROJECT FILE PATH" FontFamily="Inter, Segoe UI" FontSize="10" FontWeight="SemiBold" Foreground="#8E8E93" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathBox" Grid.Column="0" Margin="0,0,8,0" IsReadOnly="True" />
                    <Button Grid.Column="1" Content="Browse" Style="{DynamicResource SettingsBrowseBtn}" Click="BrowsePath_Click"/>
                </Grid>

                <TextBlock Text="ASSOCIATE WITH APP" FontFamily="Inter, Segoe UI" FontSize="10" FontWeight="SemiBold" Foreground="#8E8E93" Margin="0,20,0,8"/>
                <ListBox x:Name="AppSelector" Background="Transparent" BorderThickness="0" Height="170" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="24" Height="24" CornerRadius="4" Background="#2A2A2E" Margin="0,0,12,0">
                                    <Image Source="{Binding AppIcon}" Stretch="Uniform" Margin="2"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" Foreground="#F2F2F7" VerticalAlignment="Center" FontFamily="Inter, Segoe UI" FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="2" Background="#101013" Margin="1,0,1,1">
                <Grid.Clip>
                    <RectangleGeometry Rect="0,0,400,60" RadiusX="15" RadiusY="15"/>
                </Grid.Clip>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16">
                    <Button Content="Cancel" Style="{DynamicResource SettingsResetBtn}" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                    <Button Content="Add Project" Style="{DynamicResource SettingsBrowseBtn}" Background="{DynamicResource AccentBrush}" Foreground="#101013" Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
